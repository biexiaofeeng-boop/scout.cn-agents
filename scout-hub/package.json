{
  "name": "scout-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "pipeline:once": "tsx src/cli.ts pipeline --once",
    "scheduler": "tsx src/cli.ts scheduler --interval 300",
    "api": "tsx src/cli.ts api --host 127.0.0.1 --port 18080"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "mysql2": "^3.11.3",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
