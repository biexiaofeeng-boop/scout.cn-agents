# Active runtime note:
# - ops/start.sh sources this file before starting scout-vendor/mediacrawler
# - scout-vendor/mediacrawler/.env is only a vendor-side template unless you source it manually
# - choose one active save path: jsonl/json/excel/sqlite need no DB; db uses MySQL; postgres uses PostgreSQL

# MediaCrawler API runtime
MEDIACRAWLER_API_HOST=127.0.0.1
MEDIACRAWLER_API_PORT=18081

# MediaCrawler API security
# Note: current scout-vendor/mediacrawler API does not enforce these flags yet.
# Keep them populated for future auth hardening and do not rely on them as the current security boundary.
MEDIACRAWLER_API_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY
MEDIACRAWLER_API_AUTH_ENABLED=true
MEDIACRAWLER_ENABLE_DOCS=false
MEDIACRAWLER_TRUSTED_HOSTS=127.0.0.1,localhost

# Optional data stores
MYSQL_DB_HOST=127.0.0.1
MYSQL_DB_PORT=3306
MYSQL_DB_USER=root
MYSQL_DB_PWD=CHANGE_ME
MYSQL_DB_NAME=media_crawler

REDIS_DB_HOST=127.0.0.1
REDIS_DB_PORT=6379
REDIS_DB_PWD=
REDIS_DB_NUM=0

# Optional MongoDB store
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PWD=
MONGODB_DB_NAME=media_crawler

# Optional PostgreSQL store
POSTGRES_DB_HOST=127.0.0.1
POSTGRES_DB_PORT=5433
POSTGRES_DB_USER=postgres
POSTGRES_DB_PWD=CHANGE_ME
POSTGRES_DB_NAME=media_crawler

# Optional proxy providers
WANDOU_APP_KEY=CHANGE_ME_IF_USING_PROXY
KDL_SECERT_ID=CHANGE_ME_IF_USING_PROXY
KDL_SIGNATURE=CHANGE_ME_IF_USING_PROXY
KDL_USER_NAME=CHANGE_ME_IF_USING_PROXY
KDL_USER_PWD=CHANGE_ME_IF_USING_PROXY
jisu_key=CHANGE_ME_IF_USING_PROXY
jisu_crypto=CHANGE_ME_IF_USING_PROXY
