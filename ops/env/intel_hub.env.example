# intel_hub runtime settings
# Path settings are auto-resolved from the current repository by default.
# Set these only when running intel_hub against external runtime directories.
# INTEL_DB_PATH=
# INTEL_MEDIACRAWLER_ROOT=
# INTEL_WECHAT_ROOT=
INTEL_WECHAT_ENABLE_DB=true
INTEL_BATCH_SIZE=500
INTEL_ALERT_DLQ_THRESHOLD=10
# INTEL_DLQ_PATH=

# scheduler/monitor
INTEL_SCHEDULER_INTERVAL=300
INTEL_MONITOR_HOST=127.0.0.1
INTEL_MONITOR_PORT=18080

# optional WeChat DB override
WECHAT_MYSQL_HOST=127.0.0.1
WECHAT_MYSQL_PORT=3306
WECHAT_MYSQL_DB=test
WECHAT_MYSQL_USER=root
WECHAT_MYSQL_PASSWD=CHANGE_ME
