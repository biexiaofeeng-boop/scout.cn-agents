# scout-hub runtime
# Path settings are auto-resolved from the current repository by default.
# Set these only when running scout-hub against external runtime directories.
# SCOUT_PROJECT_ROOT=
# SCOUT_STATE_DIR=
# SCOUT_RUNTIME_ROOT=/Users/sourcefire/1data/scout
# SCOUT_VENDOR_ROOT=
# SCOUT_MEDIACRAWLER_ROOT=
# SCOUT_WECHAT_ROOT=
SCOUT_WECHAT_ENABLE_DB=true
SCOUT_BATCH_SIZE=500
SCOUT_ALERT_DLQ_THRESHOLD=10
SCOUT_SCHEDULER_INTERVAL_SEC=120
SCOUT_OPS_ACTION_TIMEOUT_MS=180000
SCOUT_OPS_RUN_RETENTION_DAYS=30
SCOUT_OPS_RUN_RETENTION_MAX=300
SCOUT_MONITOR_HOST=127.0.0.1
SCOUT_MONITOR_PORT=18080

# Optional provider keys. Keep empty until the provider is enabled for live collection.
# YOUTUBE_API_KEY=

WECHAT_MYSQL_HOST=127.0.0.1
WECHAT_MYSQL_PORT=3306
WECHAT_MYSQL_DB=test
WECHAT_MYSQL_USER=root
WECHAT_MYSQL_PASSWD=CHANGE_ME
