# MediaCrawler Web API
SCOUT_MEDIA_API_BASE=http://127.0.0.1:18081
SCOUT_MEDIA_API_KEY=CHANGE_ME

# Runtime policy: safe_live | debug_fast
SCOUT_MEDIA_RUNTIME_PROFILE=safe_live

# LLM expansion
# Fill a real key to enable llm_supplement generation.
SCOUT_MEDIA_LLM_API_KEY=YOUR_OPENAI_COMPATIBLE_KEY_HERE
SCOUT_MEDIA_LLM_BASE_URL=https://api.openai.com/v1
SCOUT_MEDIA_LLM_MODEL=gpt-4o-mini
SCOUT_MEDIA_LLM_TIMEOUT_MS=30000
